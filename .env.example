# Server
PORT=3000
NODE_ENV=production

# JWT Secret (ganti dengan random string panjang)
JWT_SECRET=your_super_secret_jwt_key_here

# Dashboard Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_password_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Health Check
HEALTH_CHECK_INTERVAL=30       # menit
REPORT_INTERVAL=4              # jam
HEALTH_CHECK_TIMEOUT=10000     # ms

# CORS - URL dashboard React kamu
ALLOWED_ORIGINS=https://your-dashboard.vercel.app,http://localhost:5173

# Indiwtf API (https://indiwtf.com/pricing)
INDIWTF_TOKEN=your_indiwtf_api_token_here

# Redirect Path (default path yang dipakai untuk redirect)
# Contoh: kalau isi "toko", akses via domain-master.com/toko
DEFAULT_REDIRECT_PATH=go
